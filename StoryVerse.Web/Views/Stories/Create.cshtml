                                <i data-lucide="check" style="width: 12px; height: 12px; stroke-width: 3;"></i>
                            </div>
                            <span class="text-slate-700" style="font-size: 13.5px; font-weight: 500;">Basic details look good</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-teal bg-white" style="width: 20px; height: 20px; border: 1.5px solid #0d9488;">
                                <i data-lucide="check" style="width: 12px; height: 12px; stroke-width: 3;"></i>
                            </div>
                            <span class="text-slate-700" style="font-size: 13.5px; font-weight: 500;">Genre and theme selected</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-teal bg-white" style="width: 20px; height: 20px; border: 1.5px solid #0d9488;">
                                <i data-lucide="check" style="width: 12px; height: 12px; stroke-width: 3;"></i>
                            </div>
                            <span class="text-slate-700" style="font-size: 13.5px; font-weight: 500;">Settings configured</span>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center text-teal bg-white" style="width: 20px; height: 20px; border: 1.5px solid #0d9488;">
                                <i data-lucide="check" style="width: 12px; height: 12px; stroke-width: 3;"></i>
                            </div>
                            <span class="text-slate-700" style="font-size: 13.5px; font-weight: 500;">Privacy and goals set</span>
                        </div>
                    </div>
                </div>

                <div class="card-rounded p-3 bg-white" style="border-color: #ccfbf1 !important; background-color: #f0fdfa !important;">
                    <div class="d-flex align-items-start gap-2.5">
                        <i data-lucide="sparkles" class="mt-0.5" style="width: 18px; height: 18px; color: #f59e0b;"></i>
                        <div>
                            <h6 class="fw-bold mb-1" style="color: #0f172a; font-size: 13px;">All set! Your story is ready to be created.</h6>
                            <p class="text-muted mb-0" style="font-size: 11.5px;">Click 'Create Story' to begin your writing journey.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
            
            function formatOption(opt) {
                if (!opt.id) {
                    return opt.text;
                }
                var description = $(opt.element).data('description') || '';
                if (description) {
                    return $(
                        '<div><div class="fw-bold text-slate-800" style="font-size: 13px;">' + opt.text + '</div>' +
                        '<div class="text-muted mt-1" style="font-size: 11px;">' + description + '</div></div>'
                    );
                }
                return opt.text;
            }

            $('.select2-themed').select2({
                templateResult: formatOption,
                width: '100%'
            });
            
            // Genre Selection
            $('.genre-card input[type="radio"]').on('change', function() {
                $('.genre-card').css({
                    'background-color': '#ffffff',
                    'border-color': '#e2e8f0'
                });
                $('.genre-card .check-icon').addClass('d-none');
                $('.genre-card .icon-container').css({
                    'background-color': '#f1f5f9',
                    'color': '#64748b'
                });

                if ($(this).is(':checked')) {
                    var $card = $(this).closest('.genre-card');
                    $card.css({
                        'background-color': '#f0fdfa',
                        'border-color': '#0d9488'
                    });
                    $card.find('.check-icon').removeClass('d-none');
                    $card.find('.icon-container').css({
                        'background-color': '#ccfbf1',
                        'color': '#0d9488'
                    });
                }
            });

            // Theme Selection
            $('.theme-pill input[type="checkbox"]').on('change', function() {
                var $pill = $(this).siblings('.theme-pill-label');
                if ($(this).is(':checked')) {
                    $pill.removeClass('unselected').addClass('selected');
                    var iconHtml = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x theme-icon"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
                    $pill.find('svg, i').replaceWith(iconHtml);
                } else {
                    $pill.removeClass('selected').addClass('unselected');
                    var iconHtml = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plus theme-icon" style="color: #94a3b8;"><path d="M5 12h14"/><path d="M12 5v14"/></svg>';
                    $pill.find('svg, i').replaceWith(iconHtml);
                }
            });

            // Step Navigation Logic
            function updateSteppers(currentStep) {
                // Reset all
                for (let i = 1; i <= 4; i++) {
                    let topStep = $('#top-stepper-' + i);
                    let sideStep = $('#side-stepper-' + i);
                    
                    if (i < currentStep) {
                        // Completed
                        topStep.find('.top-step-icon').html('<i data-lucide="check" style="width: 18px; height: 18px;"></i>').css({
                            'background-color': '#0d9488',
                            'color': 'white'
                        });
                        topStep.find('.top-step-label').css({'font-weight': '500', 'color': '#64748b'});
                        
                        sideStep.find('.side-step-icon').html('<i data-lucide="check" style="width: 12px; height: 12px;"></i>').css({
                            'background-color': '#0d9488',
                            'color': 'white'
                        }).removeClass('text-slate-500').addClass('text-white shadow-sm');
                    } else if (i == currentStep) {
                        // Active
                        topStep.find('.top-step-icon').html(i).css({
                            'background-color': '#0d9488',
                            'color': 'white'
                        });
                        topStep.find('.top-step-label').css({'font-weight': '700', 'color': '#0d9488'});
                        
                        sideStep.find('.side-step-icon').html(i).css({
                            'background-color': '#0d9488',
                            'color': 'white'
                        }).removeClass('text-slate-500').addClass('text-white shadow-sm');
                    } else {
                        // Pending
                        topStep.find('.top-step-icon').html(i).css({
                            'background-color': '#f1f5f9',
                            'color': '#64748b'
                        });
                        topStep.find('.top-step-label').css({'font-weight': '600', 'color': '#64748b'});
                        
                        sideStep.find('.side-step-icon').html(i).css({
                            'background-color': '#f1f5f9',
                            'color': '#64748b'
                        }).removeClass('text-white shadow-sm');
                    }
                }
                
                // Right Sidebar Toggle
                if (currentStep == 4) {
                    $('#right-whats-next').addClass('d-none');
                    $('#right-review-checklist').removeClass('d-none').addClass('d-flex');
                    updateReviewData();
                } else {
                    $('#right-whats-next').removeClass('d-none');
                    $('#right-review-checklist').addClass('d-none').removeClass('d-flex');
                }

                if (typeof lucide !== 'undefined') {
                    lucide.createIcons();
                }
            }

            function updateReviewData() {
                function getText(selector) {
                    var el = $(selector);
                    if (el.is('select')) {
                        var val = el.val();
                        if (!val) return '';
                        return el.find('option:selected').text();
                    }
                    return el.val();
                }
                function setVal(id, val) {
                    if (!val || val.trim() === '') {
                        $(id).html('<span class="text-muted fst-italic">Not set</span>');
                    } else {
                        $(id).text(val);
                    }
                }
                
                var title = getText('input[name="Title"]');
                setVal('#review-title', title);
                setVal('#review-tagline', getText('input[name="Tagline"]'));
                setVal('#review-synopsis', getText('textarea[name="Synopsis"]'));
                setVal('#review-type', getText('select[name="Genre"]'));
                setVal('#review-audience', getText('select[name="TargetAudience"]'));
                setVal('#review-language', getText('select[name="Language"]'));
                
                var primaryGenre = $('input[name="PrimaryGenre"]:checked').val();
                setVal('#review-primary-genre', primaryGenre);
                
                var themes = [];
                $('input[name="Themes"]:checked').each(function() {
                    themes.push($(this).val());
                });
                if (themes.length > 0) {
                    var themesHtml = '<div class="d-flex flex-wrap gap-1.5">';
                    themes.forEach(function(t) {
                        themesHtml += '<span class="bg-light text-slate-700 px-2 py-1 rounded" style="font-size: 11px; font-weight: 500;">' + t + '</span>';
                    });
                    themesHtml += '</div>';
                    $('#review-themes').html(themesHtml);
                } else {
                    $('#review-themes').html('<span class="text-muted fst-italic">Not set</span>');
                }
                
                setVal('#review-mood', getText('select[name="Mood"]'));
                setVal('#review-writing-style', getText('select[name="WritingStyle"]'));
                setVal('#review-pov', getText('select[name="PointOfView"]'));
                setVal('#review-tense', getText('select[name="Tense"]'));
                
                var statusText = getText('select[name="Status"]');
                if (!statusText || statusText.trim() === '') {
                    $('#review-status').html('<span class="text-muted fst-italic">Not set</span>');
                    $('#live-preview-status-container').addClass('d-none');
                } else {
                    $('#review-status').html('<div class="bg-light rounded-pill px-2 py-0.5 d-flex align-items-center gap-1.5 border d-inline-flex" style="font-size: 11px; font-weight: 600; color: #475569;"><div class="rounded-circle" style="width: 6px; height: 6px; background-color: #f59e0b;"></div> ' + statusText + '</div>');
                    $('#live-preview-status').html('<div class="rounded-circle" style="width: 6px; height: 6px; background-color: #f59e0b;"></div> ' + statusText);
                    $('#live-preview-status-container').removeClass('d-none');
                }
                
                var dailyGoal = getText('input[name="DailyWordGoal"]');
                setVal('#review-daily-goal', dailyGoal ? dailyGoal + ' words per day' : '');
                
                var targetWordCount = getText('input[name="TargetWordCount"]');
                setVal('#review-target-word-count', targetWordCount ? targetWordCount + ' words' : '');
                
                setVal('#review-target-date', getText('input[name="TargetCompletionDate"]'));
                
                var privacy = $('input[name="Privacy"]:checked').val();
                if (privacy) {
                    $('#review-privacy').html('<div class="d-flex align-items-center gap-1.5"><i data-lucide="lock" style="width: 12px; height: 12px;"></i> ' + privacy + '</div>');
                } else {
                    setVal('#review-privacy', '');
                }
                
                $('#review-ai').text($('input[name="AiAssistant"]').is(':checked') ? 'Enabled' : 'Disabled');
                $('#review-autosave').text($('input[name="AutoSave"]').is(':checked') ? 'Enabled' : 'Disabled');
                $('#review-comments').text($('input[name="AllowComments"]').is(':checked') ? 'Enabled' : 'Disabled');
                
                // Live preview updates
                $('#live-preview-title').text(title && title.trim() !== '' ? title : 'Untitled Story');
                $('#live-preview-synopsis').text(getText('textarea[name="Synopsis"]') || 'Your story synopsis will appear here...');
                $('#live-preview-language').text(getText('select[name="Language"]') || 'English');
            }
            
            function validateStep(stepIndex) {
                let isValid = true;
                let $step = $('#step-' + stepIndex);
                
                $step.find('.text-danger.validation-message').remove();
                $step.find('.is-invalid').removeClass('is-invalid');
                
                $step.find('input[required], textarea[required], select[required]').each(function() {
                    if (!$(this).val() || $(this).val().trim() === '') {
                        isValid = false;
                        $(this).addClass('is-invalid');
                        $(this).after('<div class="text-danger validation-message mt-1 fw-medium" style="font-size: 12px;">This field is required.</div>');
                    }
                });
                
                return isValid;
            }

            $('.btn-next').on('click', function() {
                var currentStep = $(this).closest('.step-content').attr('id').split('-')[1];
                if (!validateStep(currentStep)) {
                    return;
                }

                var nextStep = $(this).data('next');
                $('.step-content').addClass('d-none');
                $('#step-' + nextStep).removeClass('d-none');
                updateSteppers(nextStep);
            });

            $('.btn-back').on('click', function() {
                var prevStep = $(this).data('prev');
                $('.step-content').addClass('d-none');
                $('#step-' + prevStep).removeClass('d-none');
                updateSteppers(prevStep);
            });
            
            $('.btn-edit').on('click', function() {
                var targetStep = $(this).data('step');
                $('.step-content').addClass('d-none');
                $('#step-' + targetStep).removeClass('d-none');
                updateSteppers(targetStep);
            });
            
            // Initialize on step 4 for display
            updateSteppers(4);
            $('.step-content').addClass('d-none');
            $('#step-4').removeClass('d-none');
        });
    </script>
}
