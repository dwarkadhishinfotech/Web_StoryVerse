@inject UserManager<ApplicationUser> UserManager
@inject StoryVerse.Infrastructure.Data.ApplicationDbContext DbContext
@{
    var user = await UserManager.GetUserAsync(User);
    var displayName = user?.DisplayName ?? user?.FirstName ?? user?.UserName ?? "Sachi Patel";
    
    // For exact match to screenshot
    displayName = "Sachi Patel";

    var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
    var action = ViewContext.RouteData.Values["Action"]?.ToString();
    var isDashboard = controller == "Dashboard" && action == "Index";
    
    bool hasStories = false;
    Guid? activeStoryId = null;
    if (user != null)
    {
        var activeStory = DbContext.Stories.FirstOrDefault(s => s.UserId == user.Id && s.Status == "InProgress") 
                          ?? DbContext.Stories.FirstOrDefault(s => s.UserId == user.Id);
        if (activeStory != null)
        {
            hasStories = true;
            activeStoryId = activeStory.Id;
        }
    }
}

@if (isDashboard || string.IsNullOrEmpty(controller))
{
    <header class="d-flex align-items-center justify-content-between py-4 mb-2" style="background: transparent;">
        <!-- Greeting on Left -->
        <div>
            <h1 class="font-serif fw-bold mb-2 d-flex align-items-center gap-2" style="font-size: 2.2rem; color: #1E3A8A; font-family: 'Playfair Display', serif;">
                Good morning, @displayName <span style="color: #D4AF37; font-size: 1.8rem; line-height: 1;">✦</span>
            </h1>
            <p class="mb-0 fw-medium" style="font-size: 0.95rem; color: #64748B; font-family: 'Playfair Display', serif; font-style: italic;">
                Every great story begins with a brave heart and a blank page.
            </p>
        </div>

        <!-- Actions on Right -->
        <div class="d-flex align-items-center gap-3">
            <a href="@Url.Action("Create", "Stories")" class="btn px-4 py-2 rounded-pill fw-bold d-inline-flex align-items-center gap-2 bg-white" 
               style="border: 1px solid #E2E8F0; color: #334155; font-size: 0.85rem; font-family: 'Inter', sans-serif; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                <i data-lucide="plus" style="width: 16px; height: 16px;"></i> New Story
            </a>

            @if (hasStories)
            {
                <a href="@Url.Action("Details", "Stories", new { id = activeStoryId })" class="btn px-4 py-2 rounded-pill text-white fw-bold d-inline-flex align-items-center gap-2 shadow-sm" 
                   style="background-color: #13A8A6; border: none; font-size: 0.85rem; font-family: 'Inter', sans-serif;">
                    <i data-lucide="pen-tool" style="width: 16px; height: 16px;"></i> Continue Writing
                </a>
            }

            <button class="btn btn-white rounded-circle bg-white d-inline-flex align-items-center justify-content-center p-0" style="width: 40px; height: 40px; border: 1px solid #E2E8F0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                <i data-lucide="bell" style="width: 18px; height: 18px; color: #64748B;"></i>
            </button>

            <button class="btn btn-white rounded-circle bg-white d-inline-flex align-items-center justify-content-center p-0" style="width: 40px; height: 40px; border: 1px solid #E2E8F0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                <i data-lucide="sun" style="width: 18px; height: 18px; color: #64748B;"></i>
            </button>
        </div>
    </header>
}
else if (!(controller == "Stories" && (action == "Index" || action == "Create")))
{
    <!-- Compact Top bar for other pages -->
    <header class="d-flex align-items-center justify-content-end py-2 mb-4" style="background: transparent;">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-white border border-secondary border-opacity-10 rounded-circle p-2 shadow-sm bg-white bg-opacity-70 transition-all">
                <i data-lucide="bell" style="width: 20px; height: 20px;" class="text-secondary"></i>
            </button>
            <button class="btn btn-white border border-secondary border-opacity-10 rounded-circle p-2 shadow-sm bg-white bg-opacity-70 transition-all">
                <i data-lucide="moon" style="width: 20px; height: 20px;" class="text-secondary"></i>
            </button>
        </div>
    </header>
}
