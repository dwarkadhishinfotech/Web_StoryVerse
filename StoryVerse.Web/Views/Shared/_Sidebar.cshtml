@inject UserManager<ApplicationUser> UserManager
@{
    var user = await UserManager.GetUserAsync(User);
    var displayName = user?.DisplayName ?? user?.FirstName ?? user?.UserName ?? "Author";
    var initials = !string.IsNullOrEmpty(displayName) ? displayName[0].ToString().ToUpper() : "A";
    
    // Forcing exact match to screenshot
    displayName = "Sachi Patel";
    initials = "SP";

    var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<style>
    .sidebar-custom {
        background-color: #0A1128; /* Very dark blue from screenshot */
        position: relative;
    }
    .sidebar-nav-link {
        color: #94A3B8 !important;
        font-weight: 500 !important;
        transition: all 0.2s ease;
        padding: 10px 16px;
        border-radius: 8px;
        font-family: 'Inter', sans-serif;
    }
    .sidebar-nav-link i {
        color: #94A3B8 !important;
    }
    .sidebar-nav-link:hover {
        background-color: rgba(255, 255, 255, 0.05) !important;
        color: white !important;
    }
    .sidebar-nav-link:hover i {
        color: white !important;
    }
    .sidebar-nav-link.active {
        background-color: #13A8A6 !important;
        color: white !important;
        font-weight: 600 !important;
    }
    .sidebar-nav-link.active i {
        color: white !important;
    }
    .no-scrollbar::-webkit-scrollbar {
        display: none !important;
    }
    .no-scrollbar {
        -ms-overflow-style: none !important;
        scrollbar-width: none !important;
    }
    .streak-circle {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background-color: #1E293B;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 6px auto;
    }
</style>

<nav class="sidebar-custom shadow-lg d-flex flex-column" style="width: 250px; height: 100vh;">
    <!-- Logo Section -->
    <div class="px-4 pt-4 pb-2 d-flex align-items-center gap-3">
        <div style="height: 32px; width: 32px;">
            <img src="/images/Logo_Transparent.PNG" alt="StoryVerse Logo" class="img-fluid" onerror="this.style.display='none'" />
            <!-- Fallback if image doesn't exist -->
            <i data-lucide="feather" class="text-white" style="width:24px; height:24px; display:none;" onload="if(!this.previousElementSibling.complete || this.previousElementSibling.naturalHeight === 0) this.style.display='block';"></i>
        </div>
        <div class="d-flex flex-column">
            <span class="font-serif fw-bold text-white" style="font-size: 1.25rem; line-height: 1.1; font-family: 'Playfair Display', serif;">StoryVerse</span>
            <span class="fw-bold text-uppercase" style="font-size: 0.55rem; letter-spacing: 0.1em; color: #13A8A6; font-family: 'Inter', sans-serif;">AUTHOR OS</span>
        </div>
    </div>

    <!-- Current Workspace -->
    <div class="px-4 mt-4 mb-2">
        <div class="text-uppercase fw-bold text-white mb-2" style="font-size: 10px; letter-spacing: 0.05em; opacity: 0.6; font-family: 'Inter', sans-serif;">CURRENT WORKSPACE</div>
        <div class="d-flex align-items-center justify-content-between p-2 rounded-3 cursor-pointer" style="background: rgba(255, 255, 255, 0.05);">
            <div class="d-flex align-items-center gap-2">
                <i data-lucide="home" style="width: 16px; height: 16px; color: #94A3B8;"></i>
                <span class="text-white fw-medium" style="font-size: 0.85rem; font-family: 'Inter', sans-serif;">My Workspace</span>
            </div>
            <i data-lucide="chevron-down" style="width: 14px; height: 14px; color: #94A3B8;"></i>
        </div>
    </div>

    <!-- Navigation Menu -->
    <div class="flex-grow-1 px-3 py-3 no-scrollbar" style="overflow-y: auto;">
        <a href="@Url.Action("Index", "Dashboard")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Dashboard" || controller == null ? "active" : "")">
            <i data-lucide="layout-grid" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Dashboard</span>
        </a>
        <a href="@Url.Action("Index", "Stories")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Stories" ? "active" : "")">
            <i data-lucide="book" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Stories</span>
        </a>
        <a href="@Url.Action("Index", "Chapters")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Chapters" ? "active" : "")">
            <i data-lucide="file-text" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Chapters</span>
        </a>
        <a href="@Url.Action("Index", "Characters")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Characters" ? "active" : "")">
            <i data-lucide="users" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Characters</span>
        </a>
        <a href="@Url.Action("Index", "Timeline")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Timeline" ? "active" : "")">
            <i data-lucide="clock" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Timeline</span>
        </a>
        <a href="@Url.Action("Index", "WorldBuilding")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "WorldBuilding" ? "active" : "")">
            <i data-lucide="globe-2" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">World Building</span>
        </a>
        <a href="@Url.Action("Index", "Research")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Research" ? "active" : "")">
            <i data-lucide="search" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Research</span>
        </a>
        <a href="@Url.Action("Index", "Maps")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Maps" ? "active" : "")">
            <i data-lucide="map" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Maps</span>
        </a>
        <a href="@Url.Action("Index", "Notes")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Notes" ? "active" : "")">
            <i data-lucide="file" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Notes</span>
        </a>
        <a href="@Url.Action("Index", "Assets")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Assets" ? "active" : "")">
            <i data-lucide="folder-open" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Assets</span>
        </a>
        <a href="@Url.Action("Index", "Analytics")" class="sidebar-nav-link text-decoration-none d-flex align-items-center gap-3 mb-1 @(controller == "Analytics" ? "active" : "")">
            <i data-lucide="bar-chart-2" style="width: 18px; height: 18px;"></i>
            <span style="font-size: 0.85rem;">Analytics</span>
        </a>
    </div>

    <!-- Writing Streak -->
    <div class="px-4 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="text-uppercase fw-bold text-white" style="font-size: 10px; letter-spacing: 0.05em; opacity: 0.6; font-family: 'Inter', sans-serif;">WRITING STREAK</span>
            <span style="font-size: 14px;">🔥</span>
        </div>
        <div class="d-flex align-items-baseline gap-1 mb-1">
            <span class="fw-bold text-white" style="font-size: 1.5rem; line-height: 1;">0</span>
            <span class="text-white-50 fw-medium" style="font-size: 0.75rem;">days</span>
        </div>
        <div class="text-white-50 mb-3" style="font-size: 0.75rem; font-family: 'Inter', sans-serif;">Start your streak today!</div>
        
        <div class="d-flex justify-content-between text-center" style="font-size: 9px; font-weight: 600; color: #64748B; font-family: 'Inter', sans-serif;">
            <div><div class="streak-circle"></div>M</div>
            <div><div class="streak-circle"></div>T</div>
            <div><div class="streak-circle"></div>W</div>
            <div><div class="streak-circle"></div>T</div>
            <div><div class="streak-circle"></div>F</div>
            <div><div class="streak-circle"></div>S</div>
            <div><div class="streak-circle"></div>S</div>
        </div>
    </div>

    <!-- User Profile Footer -->
    <div class="px-4 pb-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold" style="height: 36px; width: 36px; background-color: #13A8A6; color: white; font-size: 0.9rem; font-family: 'Inter', sans-serif;">
                    @initials
                </div>
                <div class="d-flex flex-column">
                    <span class="text-white fw-bold lh-sm text-truncate" style="font-size: 0.85rem; max-width: 110px; font-family: 'Inter', sans-serif;">@displayName</span>
                    <span class="fw-medium mt-0.5" style="font-size: 11px; color: #64748B; font-family: 'Inter', sans-serif;">Author</span>
                </div>
            </div>
            <i data-lucide="chevron-down" style="width: 16px; height: 16px; color: #64748B; cursor: pointer;"></i>
        </div>
        <div class="d-flex align-items-center gap-2 text-white-50 cursor-pointer hover-text-white transition-all">
            <i data-lucide="chevron-left" style="width: 16px; height: 16px;"></i>
            <span style="font-size: 0.85rem; font-weight: 500; font-family: 'Inter', sans-serif;">Collapse</span>
        </div>
    </div>
</nav>
