<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StoryVerse</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        :root {
            --parchment-bg: #FAF5ED;
            --forest-green: #13A8A6; /* Peacock Teal */
            --forest-green-dark: #1E439B; /* Deep Blue/Indigo */
            --parchment-border: #EAE3D2;
            --parchment-card: rgba(253, 251, 247, 0.95);
            --gold-accent: #C5A880;
            --peacock-gradient: linear-gradient(135deg, #1E439B, #13A8A6);
        }
        /* Custom thin peacock scrollbars */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.02);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(19, 168, 166, 0.35);
            border-radius: 10px;
            transition: background 0.3s ease;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(19, 168, 166, 0.7);
        }
        * {
            scrollbar-width: thin;
            scrollbar-color: rgba(19, 168, 166, 0.35) rgba(0, 0, 0, 0.02);
        }
        html, body {
            max-width: 100%;
            overflow-x: hidden !important;
        }
        body {
            background-color: #FAF5ED;
            background-image: url('/backgrounds/SiteBgPage.png') !important;
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
        }
    </style>
</head>
<body class="text-slate-800 font-sans" style="margin: 0; padding: 0; overflow-x: hidden; background-color: #FAF5ED;">
    <!-- Fixed Background Illustrations -->
    <div class="position-fixed" style="bottom: 0; left: 0; width: 250px; z-index: 1; pointer-events: none; opacity: 0.85;">
        <img src="/images/dashboard/cup_tea.png" class="img-fluid" style="mix-blend-mode: multiply;" />
    </div>
    <div class="d-flex" style="height: 100vh; width: 100%; overflow: hidden; background: transparent;">
        <!-- Sidebar -->
        <partial name="_Sidebar" />

        <!-- Main Content Wrapper -->
        <main class="flex-grow-1 position-relative" style="overflow-y: auto; z-index: 10; background: transparent;">
            <div class="mx-auto" style="max-width: 1500px; padding: 1.5rem 2rem;">
                <!-- Top Navbar -->
                <partial name="_TopNavbar" />

                <!-- Main Content Area -->
                <div class="mt-4 mt-md-5">
                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <!-- Bootstrap Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Initialize Icons -->
    <script>
      lucide.createIcons();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
