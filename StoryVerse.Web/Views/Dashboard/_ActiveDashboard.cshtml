                        <svg class="w-100 h-100" style="transform: rotate(-90deg);">
                            <circle cx="38" cy="38" r="34" fill="none" stroke="#F1F5F9" stroke-width="6"></circle>
                            <circle cx="38" cy="38" r="34" fill="none" stroke="#E2E8F0" stroke-width="6" stroke-dasharray="213.6" stroke-dashoffset="213.6" stroke-linecap="round"></circle>
                        </svg>
                        <div class="position-absolute fw-bold" style="font-size: 0.9rem; color: #64748B; font-family: 'Inter', sans-serif;">
