                                <i data-lucide="search" style="width: 18px; height: 18px; color: #13A8A6;"></i> Research Something
                            </div>
                            <i data-lucide="chevron-right" style="width: 14px; height: 14px; color: #94A3B8;"></i>
                        </a>
                        
                        @if (Model != null && Model.RecentStories.Any())
