@model StoryVerse.Web.Models.DashboardViewModel
@{
    // Empty state for exact screenshot match
}

<style>
    /* Ensure the dashboard area has no opaque background so the site body texture shows through */
    .dashboard-container {
        background-color: transparent !important;
        min-height: 100vh;
        padding-top: 10px;
    }
    
    .db-card {
        background: #FFFFFF;
        border: 1px solid rgba(226, 232, 240, 0.6);
        border-radius: 20px;
        padding: 28px;
        position: relative;
        z-index: 10;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
    }
    
    /* Top row stat card specific styling */
    .stat-card-left {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 48px;
    }
    
    .stat-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-bottom: 8px;
    }
    
    .stat-decorative-line {
        width: 1px;
        height: 24px;
        background-color: rgba(226, 232, 240, 0.8);
        margin-bottom: 4px;
    }
    
    .stat-decorative-diamond {
        width: 6px;
        height: 6px;
        transform: rotate(45deg);
    }
    
    .stat-title {
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        font-weight: 700;
        color: #1E293B;
    }
    
    .stat-value {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        color: #1E3A8A; /* Dark navy */
        line-height: 1;
        margin-top: 4px;
        margin-bottom: 8px;
    }
    
    .stat-desc {
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        color: #64748B;
        line-height: 1.5;
    }
    
    .btn-teal {
        background-color: #13A8A6;
        color: white;
        border: none;
        font-family: 'Inter', sans-serif;
        font-weight: 600;
        border-radius: 9999px;
        padding: 10px 24px;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(19, 168, 166, 0.2);
    }
    .btn-teal:hover {
        background-color: #10918F;
        color: white;
        transform: translateY(-1px);
    }
    
    .btn-outline-custom {
        background-color: white;
        color: #1E293B;
        border: 1px solid #E2E8F0;
        font-family: 'Inter', sans-serif;
        font-weight: 600;
        border-radius: 9999px;
        padding: 10px 24px;
        transition: all 0.2s ease;
    }
    .btn-outline-custom:hover {
        background-color: #F8FAFC;
        transform: translateY(-1px);
    }
    
    /* Stepper Styling */
    .stepper-container {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        position: relative;
        padding-top: 10px;
    }
    
    .stepper-line {
        position: absolute;
        top: 36px;
        left: 10%;
        right: 10%;
        height: 1px;
        background-image: linear-gradient(to right, #E2E8F0 40%, rgba(255, 255, 255, 0) 20%);
        background-position: top;
        background-size: 8px 1px;
        background-repeat: repeat-x;
        z-index: 1;
    }
    
    .stepper-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        position: relative;
        z-index: 2;
        width: 80px;
    }
    
    .stepper-icon {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #FFFFFF;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 12px;
        border: 2px solid #E2E8F0;
    }
    
    .stepper-icon.active {
        border-color: #13A8A6;
        background: #FFFFFF;
    }
    
    .stepper-title {
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        font-weight: 700;
        color: #1E293B;
        margin-bottom: 4px;
    }
    
    .stepper-desc {
        font-family: 'Inter', sans-serif;
        font-size: 9px;
        color: #94A3B8;
        line-height: 1.4;
    }
    
    .section-title {
        color: #1E3A8A; 
        font-family: 'Playfair Display', serif;
        font-weight: 700;
    }
    
    .title-star {
        color: #D4AF37; 
        font-size: 14px;
    }
    
    .decorative-line {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .decorative-line::before, .decorative-line::after {
        content: '';
        height: 1px;
        background-color: #D4AF37;
        width: 30px;
        opacity: 0.5;
    }
    
    /* CSS Bookshelf */
    .css-bookshelf-container {
        position: relative;
        width: 180px;
        height: 110px;
        margin: 0 auto;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        padding-bottom: 12px;
    }
    
    .css-shelf {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 10px;
        background: linear-gradient(to bottom, #d4a373 0%, #a27242 100%);
        border-radius: 4px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1), inset 0 2px 0 rgba(255,255,255,0.2);
    }
    
    .css-shelf::before, .css-shelf::after {
        content: '';
        position: absolute;
        bottom: -6px;
        width: 12px;
        height: 6px;
        background: #795548;
        border-radius: 0 0 4px 4px;
    }
    .css-shelf::before { left: 10px; }
    .css-shelf::after { right: 10px; }
    
    .css-books {
        display: flex;
        align-items: flex-end;
        gap: 3px;
        position: relative;
        z-index: 1;
        padding: 0 16px;
    }
    
    /* Empty State Books */
    .css-book-empty {
        width: 22px;
        height: 70px;
        background: rgba(255, 255, 255, 0.4);
        border: 1px solid rgba(226, 232, 240, 0.8);
        border-radius: 2px 4px 4px 2px;
        box-shadow: -2px 0 4px rgba(0,0,0,0.02);
    }
    .css-book-empty:nth-child(1) { height: 75px; width: 24px; }
    .css-book-empty:nth-child(2) { height: 68px; }
    .css-book-empty:nth-child(3) { height: 78px; width: 26px; transform: rotate(10deg); transform-origin: bottom left; margin-left: 6px; }
    .css-book-empty:nth-child(4) { height: 62px; margin-left: 8px; }
    .css-book-empty:nth-child(5) { height: 72px; width: 20px; }
    
    /* Real Books */
    .css-book-real {
        width: 28px;
        height: 85px;
        border-radius: 2px 4px 4px 2px;
        box-shadow: -2px 0 8px rgba(0,0,0,0.1);
        position: relative;
        cursor: pointer;
        transition: transform 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .css-book-real:hover { transform: translateY(-4px); }
    .css-book-real .book-spine {
        writing-mode: vertical-rl;
        text-orientation: mixed;
        color: rgba(255,255,255,0.95);
        font-size: 10px;
        font-weight: 700;
        font-family: 'Inter', sans-serif;
        padding: 6px 0;
        text-align: center;
        transform: rotate(180deg);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-height: 100%;
    }
    
    .book-color-0 { background: linear-gradient(to right, #1E3A8A, #2563EB); border-left: 2px solid #1e40af; }
    .book-color-1 { background: linear-gradient(to right, #13A8A6, #2DD4BF); border-left: 2px solid #0f766e; }
    .book-color-2 { background: linear-gradient(to right, #D4AF37, #FDE047); border-left: 2px solid #a16207; }
    .book-color-3 { background: linear-gradient(to right, #BE123C, #F43F5E); border-left: 2px solid #9f1239; }
    .book-color-4 { background: linear-gradient(to right, #4338CA, #6366F1); border-left: 2px solid #3730a3; }
</style>

<div class="container-fluid p-0 dashboard-container">
    
    <!-- Top Row: Stats -->
    <div class="row g-4 mb-4">
        <!-- Words Written -->
        <div class="col-md-3">
            <div class="db-card h-100 d-flex gap-4 p-4">
                <div class="stat-card-left">
                    <div class="stat-card-icon" style="background: rgba(19, 168, 166, 0.08);">
                        <i data-lucide="feather" style="color: #13A8A6; width: 20px; height: 20px;"></i>
                    </div>
                    <div class="stat-decorative-line"></div>
                    <div class="stat-decorative-diamond" style="background: #E2E8F0;"></div>
                </div>
                <div>
                    <div class="stat-title">Words Written</div>
                    <div class="stat-value">@(Model?.TotalWords ?? 0)</div>
                    <div class="stat-desc">Start writing to see your<br/>word count here.</div>
                </div>
            </div>
        </div>
        <!-- Stories Created -->
        <div class="col-md-3">
            <div class="db-card h-100 d-flex gap-4 p-4">
                <div class="stat-card-left">
                    <div class="stat-card-icon" style="background: rgba(30, 58, 138, 0.06);">
                        <i data-lucide="book-open" style="color: #1E3A8A; width: 20px; height: 20px;"></i>
                    </div>
                    <div class="stat-decorative-line"></div>
                    <div class="stat-decorative-diamond" style="background: #E2E8F0;"></div>
                </div>
                <div>
                    <div class="stat-title">Active Stories</div>
                    <div class="stat-value">@(Model?.ActiveStoriesCount ?? 0)</div>
                    <div class="stat-desc">Your stories will appear<br/>here.</div>
                </div>
            </div>
        </div>
        <!-- Characters Created -->
        <div class="col-md-3">
            <div class="db-card h-100 d-flex gap-4 p-4">
                <div class="stat-card-left">
                    <div class="stat-card-icon" style="background: rgba(100, 116, 139, 0.08);">
                        <i data-lucide="users" style="color: #475569; width: 20px; height: 20px;"></i>
                    </div>
                    <div class="stat-decorative-line"></div>
                    <div class="stat-decorative-diamond" style="background: #E2E8F0;"></div>
                </div>
                <div>
                    <div class="stat-title">Characters Created</div>
                    <div class="stat-value">@(Model?.CharactersCount ?? 0)</div>
                    <div class="stat-desc">Your characters will come<br/>to life here.</div>
                </div>
            </div>
        </div>
        <!-- Worlds Built -->
        <div class="col-md-3">
            <div class="db-card h-100 d-flex gap-4 p-4">
                <div class="stat-card-left">
                    <div class="stat-card-icon" style="background: rgba(16, 185, 129, 0.08);">
                        <i data-lucide="globe-2" style="color: #10B981; width: 20px; height: 20px;"></i>
                    </div>
                    <div class="stat-decorative-line"></div>
                    <div class="stat-decorative-diamond" style="background: #E2E8F0;"></div>
                </div>
                <div>
                    <div class="stat-title">Locations Built</div>
                    <div class="stat-value">@(Model?.LocationsCount ?? 0)</div>
                    <div class="stat-desc">Build your world piece<br/>by piece.</div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Middle Row: Welcome & Progress -->
    <div class="row g-4 mb-4">
        <!-- Welcome Card -->
        <div class="col-md-9">
            <div class="db-card h-100 d-flex justify-content-between align-items-center" style="padding: 40px 48px; overflow: hidden;">
                <div style="max-width: 55%; z-index: 2;">
                    <h2 class="section-title mb-2" style="font-size: 2.2rem;">Welcome to your Author Workspace</h2>
                    
                    <div class="decorative-line mb-4">
                        <span style="color: #D4AF37; font-size: 10px;">✦</span>
                    </div>
                    
                    <p class="mb-5" style="color: #64748B; font-size: 1rem; line-height: 1.6; font-family: 'Inter', sans-serif;">
                        This is where your imagination becomes reality.<br/>
                        Create your first story and begin your journey.
                    </p>
                    <div class="d-flex gap-3">
                        @if (Model == null || !Model.RecentStories.Any())
                        {
                            <a href="@Url.Action("Create", "Stories")" class="btn-teal text-decoration-none d-flex align-items-center gap-2">
                                <i data-lucide="plus" style="width: 16px; height: 16px;"></i> Create Your First Story
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Index", "Stories")" class="btn-teal text-decoration-none d-flex align-items-center gap-2">
                                <i data-lucide="book-open" style="width: 16px; height: 16px;"></i> View Your Stories
                            </a>
                        }
                        <button class="btn-outline-custom d-flex align-items-center gap-2">
                            <i data-lucide="play" style="width: 16px; height: 16px;"></i> Watch 2 Min Tour
                        </button>
                    </div>
                </div>
                <!-- Welcome Illustration -->
                <div style="position: absolute; right: 0; bottom: -20px; width: 45%; height: 120%; z-index: 1; display: flex; align-items: flex-end; justify-content: flex-end; pointer-events: none;">
                    <img src="/images/dashboard/welcome_hero.png" alt="Illustration" style="max-width: 130%; max-height: 130%; object-fit: contain; transform-origin: bottom right; mix-blend-mode: multiply;" onerror="this.src='/images/dashboard/quill_ink.png'" />
                </div>
            </div>
        </div>
        
        <!-- Your Progress -->
        <div class="col-md-3">
            <div class="db-card h-100 d-flex flex-column text-center">
                <h3 class="section-title text-start mb-4" style="font-size: 1.15rem;">Your Progress</h3>
                
                <div class="flex-grow-1 d-flex flex-column justify-content-center align-items-center">
                    <div class="stat-card-icon mb-4" style="width: 64px; height: 64px; background: rgba(212, 175, 55, 0.08);">
                        <i data-lucide="feather" style="color: #13A8A6; width: 28px; height: 28px;"></i>
                    </div>
                    <h4 class="fw-bold mb-2" style="font-size: 0.95rem; color: #1E293B; font-family: 'Inter', sans-serif; line-height: 1.4;">Your writing journey<br/>starts here</h4>
                    <p class="mb-4" style="font-size: 0.75rem; color: #64748B; font-family: 'Inter', sans-serif; max-width: 200px; margin: 0 auto; line-height: 1.5;">
                        Complete your first chapter to unlock your progress.
                    </p>
                    <a href="#" class="text-decoration-none fw-bold mt-auto pb-2" style="color: #13A8A6; font-size: 0.75rem; font-family: 'Inter', sans-serif;">
                        Learn how StoryVerse works &rarr;
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Bottom Row -->
    <div class="row g-4">
        <!-- Col 1: Story Shelf & Recent Activity -->
        <div class="col-md-3 d-flex flex-column gap-4">
            <!-- Story Shelf -->
            <div class="db-card flex-grow-1 text-center d-flex flex-column">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="title-star">✦</span>
                    <h3 class="section-title mb-0 text-start" style="font-size: 1.15rem;">Your Story Shelf</h3>
                </div>
                
                <div class="my-4 flex-grow-1 d-flex align-items-center justify-content-center">
                    <div class="css-bookshelf-container">
                        <div class="css-shelf"></div>
                        <div class="css-books">
                            @if (Model != null && Model.RecentStories != null && Model.RecentStories.Any())
                            {
                                int colorIdx = 0;
                                foreach (var story in Model.RecentStories.Take(5))
                                {
                                    <div class="css-book-real book-color-@(colorIdx % 5)" title="@story.Title">
                                        <div class="book-spine">@story.Title</div>
                                    </div>
                                    colorIdx++;
                                }
                            }
                            else
                            {
                                <div class="css-book-empty"></div>
                                <div class="css-book-empty"></div>
                                <div class="css-book-empty"></div>
                                <div class="css-book-empty"></div>
                                <div class="css-book-empty"></div>
                            }
                        </div>
                    </div>
                </div>
                
                @if (Model != null && Model.RecentStories != null && Model.RecentStories.Any())
                {
                    <h4 class="fw-bold mb-1" style="font-size: 0.9rem; color: #1E293B; font-family: 'Inter', sans-serif;">Continue your journey</h4>
                    <p class="mb-4" style="font-size: 0.75rem; color: #64748B; font-family: 'Inter', sans-serif;">Pick up where you left off.</p>
                }
                else
                {
                    <h4 class="fw-bold mb-1" style="font-size: 0.9rem; color: #1E293B; font-family: 'Inter', sans-serif;">Your shelf is empty</h4>
                    <p class="mb-4" style="font-size: 0.75rem; color: #64748B; font-family: 'Inter', sans-serif;">Create your first story to see it here.</p>
                }
                
                @if (Model == null || !Model.RecentStories.Any())
                {
                    <a href="@Url.Action("Create", "Stories")" class="btn-teal text-decoration-none d-inline-flex align-items-center justify-content-center gap-2 w-100 mt-auto" style="font-size: 0.8rem; padding: 10px 16px;">
                        <i data-lucide="plus" style="width: 16px; height: 16px;"></i> Add Your First Story
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Index", "Stories")" class="btn-teal text-decoration-none d-inline-flex align-items-center justify-content-center gap-2 w-100 mt-auto" style="font-size: 0.8rem; padding: 10px 16px;">
                        <i data-lucide="list" style="width: 16px; height: 16px;"></i> View All Stories
                    </a>
                }
            </div>
            
            <!-- Recent Activity -->
            <div class="db-card text-center d-flex flex-column" style="min-height: 250px;">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="title-star">✦</span>
                    <h3 class="section-title mb-0 text-start" style="font-size: 1.15rem;">Recent Activity</h3>
                </div>
                
                <div class="my-3 flex-grow-1 d-flex align-items-center justify-content-center">
                    <img src="/images/dashboard/quill_ink.png" alt="Activity" style="width: 80px; height: auto; opacity: 0.8;" onerror="this.style.display='none'" />
                </div>
                
                <h4 class="fw-bold mb-1" style="font-size: 0.9rem; color: #1E293B; font-family: 'Inter', sans-serif;">No recent activity</h4>
                <p class="mb-4" style="font-size: 0.75rem; color: #64748B; font-family: 'Inter', sans-serif;">Your writing activity will appear here.</p>
                
                <a href="@(Model == null || !Model.RecentStories.Any() ? Url.Action("Create", "Stories") : Url.Action("Index", "Stories"))" class="btn-outline-custom text-decoration-none w-100 mt-auto" style="font-size: 0.8rem; padding: 10px 16px;">
                    Start Writing
                </a>
            </div>
        </div>
        
        <!-- Col 2: Let's Get You Started & Quick Actions -->
        <div class="col-md-6 d-flex flex-column gap-4">
            <!-- Let's Get You Started -->
            <div class="db-card">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="title-star">✦</span>
                    <h3 class="section-title mb-0" style="font-size: 1.15rem;">Let's Get You Started</h3>
                </div>
                <p class="mb-5" style="font-size: 0.8rem; color: #64748B; font-family: 'Inter', sans-serif; padding-left: 24px;">Follow these simple steps to begin your writing journey.</p>
                
                <div class="stepper-container px-2 pb-2">
                    <div class="stepper-line"></div>
                    
                    <!-- Step 1 -->
                    <div class="stepper-step">
                        <div class="stepper-icon active">
                            <i data-lucide="book" style="color: #13A8A6; width: 22px; height: 22px;"></i>
                        </div>
                        <div class="stepper-title">Create Story</div>
                        <div class="stepper-desc">Build the foundation<br/>of your world</div>
                    </div>
                    
                    <!-- Step 2 -->
                    <div class="stepper-step">
                        <div class="stepper-icon">
                            <i data-lucide="file-text" style="color: #94A3B8; width: 22px; height: 22px;"></i>
                        </div>
                        <div class="stepper-title" style="color: #64748B;">Write Chapter</div>
                        <div class="stepper-desc">Start writing your<br/>first chapter</div>
                    </div>
                    
                    <!-- Step 3 -->
                    <div class="stepper-step">
                        <div class="stepper-icon">
                            <i data-lucide="users" style="color: #94A3B8; width: 22px; height: 22px;"></i>
                        </div>
                        <div class="stepper-title" style="color: #64748B;">Create Character</div>
                        <div class="stepper-desc">Bring your characters<br/>to life</div>
                    </div>
                    
                    <!-- Step 4 -->
                    <div class="stepper-step">
                        <div class="stepper-icon">
                            <i data-lucide="globe-2" style="color: #94A3B8; width: 22px; height: 22px;"></i>
                        </div>
                        <div class="stepper-title" style="color: #64748B;">Build World</div>
                        <div class="stepper-desc">Design your world<br/>and its rules</div>
                    </div>
                    
                    <!-- Step 5 -->
                    <div class="stepper-step">
                        <div class="stepper-icon">
                            <i data-lucide="search" style="color: #94A3B8; width: 22px; height: 22px;"></i>
                        </div>
                        <div class="stepper-title" style="color: #64748B;">Research</div>
                        <div class="stepper-desc">Collect ideas and<br/>inspiration</div>
                    </div>
                </div>
            </div>
            
            <!-- Quick Actions -->
            <div class="db-card flex-grow-1">
                <h3 class="section-title mb-4" style="font-size: 1.15rem;">Quick Actions</h3>
                
                <div class="row g-4 mt-2">
                    <div class="col-6 d-flex flex-column gap-4">
                        @if (Model != null && Model.RecentStories.Any())
                        {
                            <a href="@Url.Action("Create", "Chapters")" class="text-decoration-none d-flex justify-content-between align-items-center group" style="color: #334155; font-size: 0.85rem; font-family: 'Inter', sans-serif; font-weight: 600;">
                                <div class="d-flex align-items-center gap-3">
                                    <i data-lucide="file-plus-2" style="width: 18px; height: 18px; color: #13A8A6;"></i> Create New Chapter
                                </div>
                                <i data-lucide="chevron-right" style="width: 14px; height: 14px; color: #94A3B8;"></i>
                            </a>
                            
                            <a href="@Url.Action("Create", "Characters")" class="text-decoration-none d-flex justify-content-between align-items-center" style="color: #334155; font-size: 0.85rem; font-family: 'Inter', sans-serif; font-weight: 600;">
                                <div class="d-flex align-items-center gap-3">
                                    <i data-lucide="user-plus" style="width: 18px; height: 18px; color: #13A8A6;"></i> Add New Character
                                </div>
                                <i data-lucide="chevron-right" style="width: 14px; height: 14px; color: #94A3B8;"></i>
                            </a>
                        }
                        
                        <a href="@Url.Action("Index", "WorldBuilding")" class="text-decoration-none d-flex justify-content-between align-items-center" style="color: #334155; font-size: 0.85rem; font-family: 'Inter', sans-serif; font-weight: 600;">
                            <div class="d-flex align-items-center gap-3">
