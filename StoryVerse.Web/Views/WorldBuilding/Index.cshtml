@model IEnumerable<StoryVerse.Core.Entities.Location>
@{
    var story = ViewBag.Story as StoryVerse.Core.Entities.Story;
    ViewData["Title"] = $"World Building - {story?.Title}";
}

<div class="w-full pb-5 relative z-10 font-sans text-slate-800">
    <!-- Header Section -->
    <div class="d-flex align-items-center justify-content-between mb-4 mt-2">
        <div>
            <h2 class="font-serif fw-bold text-slate-900 mb-1" style="font-size: 28px; color: var(--forest-green-dark);">
                World Building <span class="text-warning fs-4">✦</span>
            </h2>
            <p class="text-secondary mb-0" style="font-size: 0.875rem;">Build and map the lore, factions, and locations of your story world.</p>
        </div>

        <div class="d-flex gap-2">
            <a href="@Url.Action("Details", "Stories", new { id = story?.Id })" class="btn btn-outline-secondary rounded-pill px-4 py-2 d-flex align-items-center hover-lift-subtle" style="font-size: 0.85rem; font-weight: 700; border-color: var(--parchment-border) !important;">
                <i data-lucide="arrow-left" class="me-1.5" style="width: 16px; height: 16px;"></i> Story Overview
            </a>

            <button class="btn text-white rounded-pill px-4 py-2 d-flex align-items-center shadow-sm hover-lift-subtle" 
                    style="background: var(--peacock-gradient); font-size: 0.85rem; font-weight: 700; border: none;"
                    data-bs-toggle="modal" data-bs-target="#newLocationModal">
                <i data-lucide="plus" class="me-1.5" style="width: 16px; height: 16px;"></i> New Location
            </button>
        </div>
    </div>

    <!-- Stats summary grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-3 col-sm-6">
            <div class="dashboard-glass-panel p-4" style="background: var(--parchment-card); border: 1px solid var(--parchment-border);">
                <span class="text-secondary fw-semibold text-uppercase d-block mb-1" style="font-size: 10px; letter-spacing: 0.05em;">Total Entities</span>
                <h3 class="fw-bold text-slate-800 mb-0 font-serif">45</h3>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="dashboard-glass-panel p-4" style="background: var(--parchment-card); border: 1px solid var(--parchment-border);">
                <span class="text-secondary fw-semibold text-uppercase d-block mb-1" style="font-size: 10px; letter-spacing: 0.05em;">Locations Mapped</span>
                <h3 class="fw-bold text-slate-800 mb-0 font-serif">@Model.Count()</h3>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="dashboard-glass-panel p-4" style="background: var(--parchment-card); border: 1px solid var(--parchment-border);">
                <span class="text-secondary fw-semibold text-uppercase d-block mb-1" style="font-size: 10px; letter-spacing: 0.05em;">Factions & Guilds</span>
                <h3 class="fw-bold text-slate-800 mb-0 font-serif">6</h3>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="dashboard-glass-panel p-4" style="background: var(--parchment-card); border: 1px solid var(--parchment-border);">
                <span class="text-secondary fw-semibold text-uppercase d-block mb-1" style="font-size: 10px; letter-spacing: 0.05em;">Lore Categories</span>
                <h3 class="fw-bold text-slate-800 mb-0 font-serif">5</h3>
            </div>
        </div>
    </div>

    <!-- Category Grid cards -->
    <h5 class="font-serif fw-bold text-slate-900 mb-3">Entity Categories</h5>
    <div class="row g-4 mb-5">
        <div class="col-md-3 col-sm-6">
            <div class="card border shadow-xs rounded-4 p-4 text-center cursor-pointer hover-lift-subtle" style="background: var(--parchment-card); border-color: var(--parchment-border) !important;">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3 text-peacock-teal" style="width: 48px; height: 48px;">
                    <i data-lucide="map-pin"></i>
                </div>
                <h6 class="fw-bold text-slate-800 mb-1">Locations</h6>
                <small class="text-secondary">@Model.Count() mapped</small>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border shadow-xs rounded-4 p-4 text-center cursor-pointer hover-lift-subtle" style="background: var(--parchment-card); border-color: var(--parchment-border) !important;">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3 text-peacock-dark" style="width: 48px; height: 48px;">
                    <i data-lucide="shield"></i>
                </div>
                <h6 class="fw-bold text-slate-800 mb-1">Organizations</h6>
                <small class="text-secondary">6 factions</small>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border shadow-xs rounded-4 p-4 text-center cursor-pointer hover-lift-subtle" style="background: var(--parchment-card); border-color: var(--parchment-border) !important;">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3 text-warning" style="width: 48px; height: 48px;">
                    <i data-lucide="globe"></i>
                </div>
                <h6 class="fw-bold text-slate-800 mb-1">Cultures & Lore</h6>
                <small class="text-secondary">4 mapped</small>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="card border shadow-xs rounded-4 p-4 text-center cursor-pointer hover-lift-subtle" style="background: var(--parchment-card); border-color: var(--parchment-border) !important;">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3 text-danger" style="width: 48px; height: 48px;">
                    <i data-lucide="award"></i>
                </div>
                <h6 class="fw-bold text-slate-800 mb-1">Artifacts</h6>
                <small class="text-secondary">12 elements</small>
            </div>
        </div>
    </div>

    <!-- Active locations list from database -->
    <h5 class="font-serif fw-bold text-slate-900 mb-3">Mapped Locations</h5>
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var loc in Model)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card border shadow-xs rounded-4 p-3 d-flex flex-row align-items-center justify-content-between bg-white" style="border-color: #F1F5F9 !important;">
                        <div class="d-flex align-items-center gap-2">
                            <div class="rounded p-2 bg-light text-peacock-teal">
                                <i data-lucide="map-pin" style="width: 20px; height: 20px;"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0 text-slate-800">@loc.Name</h6>
                                <small class="text-secondary">Created @loc.CreatedAt.ToString("MM/dd/yyyy")</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted mb-0">No locations mapped yet. Add locations to populate your world map.</p>
            </div>
        }
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="newLocationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="p-4">
                <h4 class="font-serif fw-bold text-slate-800 mb-2">Create Location</h4>
                <p class="text-secondary small mb-4">Add a new city, region, or visual landmark to your world-building records.</p>
                
                <form onsubmit="event.preventDefault(); bootstrap.Modal.getInstance(document.getElementById('newLocationModal')).hide();">
                    <div class="mb-4">
                        <label class="form-label fw-semibold small text-uppercase text-slate-500">Location Name</label>
                        <input type="text" class="form-control rounded-3" placeholder="e.g. Citadel of Aethelgard" required />
                    </div>
                    
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn text-white rounded-pill px-4 fw-bold" style="background: var(--peacock-gradient); border: none;">Create Location</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
