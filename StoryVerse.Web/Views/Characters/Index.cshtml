@model IEnumerable<StoryVerse.Core.Entities.Character>
@{
    var story = ViewBag.Story as StoryVerse.Core.Entities.Story;
    ViewData["Title"] = $"Characters - {(story?.Title ?? "All Stories")}";
}

<div class="w-full pb-5 relative z-10 font-sans text-slate-800" style="min-height: 100vh; padding: 20px;">
    <!-- Top Header Navigation Area -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <h2 class="font-serif fw-bold text-slate-900 mb-0" style="font-size: 32px; color: #1a2b3c;">
                    Characters 
                </h2>
                <div class="d-flex align-items-center text-secondary">
                    <i data-lucide="users" style="width: 20px; height: 20px; margin-right: 4px;"></i>
                    <span class="text-warning fs-5">✦</span>
                </div>
            </div>
            <p class="text-secondary mb-0" style="font-size: 0.9rem; color: #64748b;">Every unforgettable story begins with unforgettable characters.</p>
        </div>
        
        <div class="d-flex align-items-center gap-3">
            <a href="@Url.Action("Create", "Characters", new { storyId = story?.Id })" class="btn btn-outline-secondary rounded-pill px-3 py-2 d-flex align-items-center bg-white shadow-sm" style="font-size: 0.85rem; font-weight: 600; border-color: #e2e8f0; color: #0d9488;">
                <i data-lucide="plus" class="me-1.5" style="width: 16px; height: 16px;"></i> New Character
            </a>
            <div class="dropdown">
                <button class="btn rounded-pill px-4 py-2 d-flex align-items-center text-white dropdown-toggle shadow-sm" style="background-color: #0d9488; font-size: 0.85rem; font-weight: 600; border: none;" data-bs-toggle="dropdown">
                    <i data-lucide="feather" class="me-2" style="width: 16px; height: 16px;"></i> New Story
                </button>
                <ul class="dropdown-menu border-0 shadow-sm rounded-3">
                    <li><a class="dropdown-item" href="@Url.Action("Create", "Stories")">Create New Story</a></li>
                </ul>
            </div>
            <button class="btn btn-white rounded-circle bg-white d-inline-flex align-items-center justify-content-center p-0 shadow-sm" style="width: 40px; height: 40px; border: 1px solid #E2E8F0;">
                <i data-lucide="bell" style="width: 18px; height: 18px; color: #64748B;"></i>
            </button>
            <button class="btn btn-white rounded-circle bg-white d-inline-flex align-items-center justify-content-center p-0 shadow-sm" style="width: 40px; height: 40px; border: 1px solid #E2E8F0;">
                <i data-lucide="moon" style="width: 18px; height: 18px; color: #64748B;"></i>
            </button>
        </div>
    </div>

    <!-- Stats row -->
    <div class="row g-0 mb-4 bg-white rounded-4 border shadow-sm position-relative overflow-hidden" style="border-color: #e2e8f0 !important;">
        <div class="col-md-3 border-end">
            <div class="p-4 d-flex align-items-center gap-3" style="background-color: rgba(248, 250, 252, 0.5);">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background: rgba(13, 148, 136, 0.1); color: #0d9488;">
                    <i data-lucide="user"></i>
                </div>
                <div>
                    <span class="fw-semibold d-block" style="font-size: 11px; color: #0f172a;">Total Characters</span>
                    <h4 class="fw-bold mb-0" style="color: #0f172a;">@Model.Count()</h4>
                    <span class="text-secondary" style="font-size: 11px;">No characters yet</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 border-end">
            <div class="p-4 d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-warning" style="width: 48px; height: 48px; background: rgba(245, 158, 11, 0.1);">
                    <i data-lucide="star"></i>
                </div>
                <div>
                    <span class="text-secondary fw-semibold d-block" style="font-size: 11px;">Main Characters</span>
                    <h4 class="fw-bold mb-0 text-slate-800">@Model.Count(c => c.Role != null && c.Role.Contains("Protagonist"))</h4>
                    <span class="text-secondary" style="font-size: 11px;">Protagonists & Antagonists</span>
                </div>
            </div>
        </div>
        <div class="col-md-3 border-end">
            <div class="p-4 d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background: rgba(16, 185, 129, 0.1); color: #10b981;">
                    <i data-lucide="users"></i>
                </div>
                <div>
                    <span class="text-secondary fw-semibold d-block" style="font-size: 11px;">Supporting Characters</span>
                    <h4 class="fw-bold mb-0 text-slate-800">@Model.Count(c => c.Role != null && c.Role.Contains("Supporting"))</h4>
                    <span class="text-secondary" style="font-size: 11px;">Side characters & allies</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-4 d-flex align-items-center gap-3 relative">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background: rgba(59, 130, 246, 0.1); color: #3b82f6;">
                    <i data-lucide="feather"></i>
                </div>
                <div>
                    <span class="text-secondary fw-semibold d-block" style="font-size: 11px;">Minor Characters</span>
                    <h4 class="fw-bold mb-0 text-slate-800">@Model.Count(c => c.Role != null && c.Role.Contains("Minor"))</h4>
                    <span class="text-secondary" style="font-size: 11px;">Background characters</span>
                </div>
            </div>
        </div>
        
        <!-- Background decorative image in top right -->
        <div class="position-absolute end-0 top-0 h-100" style="width: 250px; z-index: 0; opacity: 0.7; background-image: url('/images/character_empty_state.png'); background-size: cover; background-position: center; mix-blend-mode: multiply; mask-image: linear-gradient(to right, transparent, black); -webkit-mask-image: linear-gradient(to right, transparent, black);">
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Content Area -->
        <div class="col-lg-8 col-xl-9">
            
            <!-- Filters & Toolbar -->
            <div class="d-flex flex-wrap gap-2 mb-3 align-items-center justify-content-between">
                <div class="d-flex gap-2 flex-grow-1 flex-wrap">
                    <div class="position-relative">
                        <i data-lucide="search" class="position-absolute text-secondary" style="left: 12px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px;"></i>
                        <input type="text" class="form-control bg-white rounded-3 shadow-sm border-0" placeholder="Search characters..." style="padding-left: 36px; min-width: 200px; font-size: 0.85rem;" />
                    </div>
                    
                    <select class="form-select bg-white rounded-3 shadow-sm border-0 w-auto" style="font-size: 0.85rem; color: #475569;">
                        <option>All Stories</option>
                    </select>
                    
                    <select class="form-select bg-white rounded-3 shadow-sm border-0 w-auto" style="font-size: 0.85rem; color: #475569;">
                        <option>All Roles</option>
                    </select>
                    
                    <select class="form-select bg-white rounded-3 shadow-sm border-0 w-auto" style="font-size: 0.85rem; color: #475569;">
                        <option>All Arcs</option>
                    </select>
                    
                    <select class="form-select bg-white rounded-3 shadow-sm border-0 w-auto" style="font-size: 0.85rem; color: #475569;">
                        <option>All Status</option>
                    </select>
                </div>
                
                <div class="d-flex gap-2 align-items-center">
                    <select class="form-select bg-white rounded-3 shadow-sm border-0 w-auto" style="font-size: 0.85rem; color: #475569;">
                        <option>Sort by: Recently Added</option>
                    </select>
                    
                    <div class="bg-white rounded-3 shadow-sm border-0 d-flex p-1">
                        <button class="btn btn-sm btn-light rounded bg-white text-secondary" style="color: #0d9488 !important; background-color: rgba(13, 148, 136, 0.1) !important;">
                            <i data-lucide="grid" style="width: 16px; height: 16px;"></i>
                        </button>
                        <button class="btn btn-sm btn-light rounded bg-white text-secondary border-0">
                            <i data-lucide="list" style="width: 16px; height: 16px;"></i>
                        </button>
                    </div>
                </div>
            </div>
            
            <!-- Empty State Section -->
            <div class="bg-white rounded-4 border shadow-sm p-5 text-center d-flex flex-column align-items-center justify-content-center mb-4 position-relative overflow-hidden" style="min-height: 480px; border-color: #e2e8f0 !important;">
                <!-- Decorative leaves in corners -->
                <i data-lucide="feather" class="position-absolute text-secondary opacity-10" style="width: 200px; height: 200px; bottom: -40px; left: -40px; transform: rotate(45deg);"></i>
                <i data-lucide="feather" class="position-absolute text-secondary opacity-10" style="width: 200px; height: 200px; bottom: -40px; right: -40px; transform: rotate(-45deg);"></i>

                <img src="/images/character_empty_state.png" alt="No Characters" class="mb-4" style="max-width: 320px; height: auto; mix-blend-mode: multiply;" />
                
                <h3 class="font-serif fw-bold text-slate-900 mb-2" style="font-size: 26px;">No characters created yet</h3>
                <p class="text-secondary mb-4" style="max-width: 420px; line-height: 1.6; font-size: 0.95rem;">
                    Your characters are waiting to come to life.<br/>Create your first character and start building the heart of your story.
                </p>
                
                <a href="@Url.Action("Create", "Characters", new { storyId = story?.Id })" class="btn text-white rounded-pill px-4 py-2.5 mb-3 fw-semibold shadow-sm" style="background-color: #0d9488; border: none; font-size: 0.9rem;">
                    <i data-lucide="plus" class="me-1.5" style="width: 16px; height: 16px;"></i> Create Your First Character
                </a>
                
                <a href="#" class="btn btn-outline-secondary rounded-pill px-4 py-2 d-flex align-items-center justify-content-center bg-white border" style="color: #0d9488; font-size: 0.85rem; font-weight: 600; border-color: #e2e8f0 !important;">
                    <i data-lucide="play-circle" class="me-1.5" style="width: 16px; height: 16px;"></i> Learn How to Create Great Characters
                </a>
            </div>
            
            <!-- Need Inspiration Section -->
            <div class="mb-2">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="text-warning"><i data-lucide="sparkles" style="width: 20px; height: 20px;"></i></span>
                    <h5 class="fw-bold text-slate-800 mb-0 font-serif" style="font-size: 16px;">Need Inspiration?</h5>
                </div>
                <p class="text-secondary small mb-3">Explore resources to create compelling characters.</p>
                
                <div class="d-flex flex-nowrap gap-3 overflow-auto pb-2">
                    <div class="bg-white rounded-3 p-3 border shadow-sm d-flex align-items-center gap-3 flex-shrink-0" style="border-color: #e2e8f0 !important; width: 220px;">
                        <div class="text-success p-2 rounded" style="background: rgba(16, 185, 129, 0.1);">
                            <i data-lucide="file-text" style="width: 20px; height: 20px;"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size: 12.5px; color: #1e293b;">Character Templates</h6>
                            <p class="text-secondary mb-0" style="font-size: 11px; line-height: 1.3;">Use proven templates for your characters</p>
                        </div>
                    </div>
                    <div class="bg-white rounded-3 p-3 border shadow-sm d-flex align-items-center gap-3 flex-shrink-0" style="border-color: #e2e8f0 !important; width: 220px;">
                        <div class="text-warning p-2 rounded" style="background: rgba(245, 158, 11, 0.1);">
                            <i data-lucide="smile" style="width: 20px; height: 20px;"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size: 12.5px; color: #1e293b;">Personality Traits</h6>
                            <p class="text-secondary mb-0" style="font-size: 11px; line-height: 1.3;">Explore traits and characteristics</p>
                        </div>
                    </div>
                    <div class="bg-white rounded-3 p-3 border shadow-sm d-flex align-items-center gap-3 flex-shrink-0" style="border-color: #e2e8f0 !important; width: 220px;">
                        <div class="p-2 rounded" style="background: rgba(217, 119, 6, 0.1); color: #d97706;">
                            <i data-lucide="map" style="width: 20px; height: 20px;"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size: 12.5px; color: #1e293b;">Character Arcs</h6>
                            <p class="text-secondary mb-0" style="font-size: 11px; line-height: 1.3;">Build meaningful character journeys</p>
                        </div>
                    </div>
                    <div class="bg-white rounded-3 p-3 border shadow-sm d-flex align-items-center gap-3 flex-shrink-0" style="border-color: #e2e8f0 !important; width: 220px;">
                        <div class="text-info p-2 rounded" style="background: rgba(14, 165, 233, 0.1);">
                            <i data-lucide="feather" style="width: 20px; height: 20px;"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1" style="font-size: 12.5px; color: #1e293b;">Naming Ideas</h6>
                            <p class="text-secondary mb-0" style="font-size: 11px; line-height: 1.3;">Find the perfect names</p>
                        </div>
                    </div>
                    
                    <div class="bg-white rounded-3 p-3 border shadow-sm d-flex align-items-center justify-content-center gap-2 flex-shrink-0" style="border-color: #e2e8f0 !important; width: 180px;">
                        <div class="d-flex align-items-center gap-2 text-decoration-none" style="color: #0d9488; font-size: 0.85rem; font-weight: 600;">
                            <i data-lucide="book-open" style="width: 16px; height: 16px;"></i> View All Resources <i data-lucide="arrow-right" style="width: 14px; height: 14px;"></i>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
        
        <!-- Right Sidebar Area -->
        <div class="col-lg-4 col-xl-3">
            
            <!-- Character Categories -->
            <div class="bg-white rounded-4 border shadow-sm p-4 mb-4" style="border-color: #e2e8f0 !important;">
                <h6 class="font-serif fw-bold text-slate-900 mb-4" style="font-size: 16px;">Character Categories</h6>
                
                <ul class="list-unstyled mb-4">
                    <li class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom" style="border-color: #f1f5f9 !important;">
                        <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; font-weight: 600; color: #334155;">
                            <i data-lucide="crown" class="text-success" style="width: 16px; height: 16px;"></i>
                            Protagonist
                        </div>
                        <span class="text-secondary small">0</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom" style="border-color: #f1f5f9 !important;">
                        <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; font-weight: 600; color: #334155;">
                            <i data-lucide="shield" class="text-danger" style="width: 16px; height: 16px;"></i>
                            Antagonist
                        </div>
                        <span class="text-secondary small">0</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom" style="border-color: #f1f5f9 !important;">
                        <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; font-weight: 600; color: #334155;">
                            <i data-lucide="users" class="text-primary" style="width: 16px; height: 16px;"></i>
                            Supporting
                        </div>
                        <span class="text-secondary small">0</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom" style="border-color: #f1f5f9 !important;">
                        <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; font-weight: 600; color: #334155;">
                            <i data-lucide="user-check" style="width: 16px; height: 16px; color: #6366f1;"></i>
                            Mentor
                        </div>
                        <span class="text-secondary small">0</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom" style="border-color: #f1f5f9 !important;">
                        <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; font-weight: 600; color: #334155;">
                            <i data-lucide="heart" class="text-danger" style="width: 16px; height: 16px;"></i>
                            Love Interest
                        </div>
                        <span class="text-secondary small">0</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom" style="border-color: #f1f5f9 !important;">
                        <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; font-weight: 600; color: #334155;">
                            <i data-lucide="link" class="text-info" style="width: 16px; height: 16px;"></i>
                            Ally
                        </div>
                        <span class="text-secondary small">0</span>
                    </li>
                    <li class="d-flex justify-content-between align-items-center mb-4">
                        <div class="d-flex align-items-center gap-2" style="font-size: 0.85rem; font-weight: 600; color: #334155;">
                            <i data-lucide="box" class="text-secondary" style="width: 16px; height: 16px;"></i>
                            Other
                        </div>
                        <span class="text-secondary small">0</span>
                    </li>
                </ul>
                
                <a href="#" class="d-flex align-items-center gap-2 text-decoration-none" style="color: #0d9488; font-size: 0.85rem; font-weight: 600;">
                    <i data-lucide="settings" style="width: 16px; height: 16px;"></i> Manage Categories
                </a>
            </div>
            
            <!-- Writing Tip -->
            <div class="bg-white rounded-4 border shadow-sm p-4" style="border-color: #e2e8f0 !important;">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i data-lucide="lightbulb" style="width: 18px; height: 18px; color: #475569;"></i>
                    <h6 class="font-serif fw-bold text-slate-900 mb-0" style="font-size: 16px;">Writing Tip</h6>
                </div>
                
                <div class="position-relative mb-4 mt-2">
                    <p class="text-secondary fst-italic mb-0" style="font-size: 0.9rem; line-height: 1.6; position: relative; z-index: 1;">
                        <span class="fw-bold fs-3 text-secondary opacity-25 me-1" style="line-height: 0;">&ldquo;</span>
                        Great characters are the heartbeat of unforgettable stories. Give them depth, flaws, and dreams. Make them real.
                        <span class="fw-bold fs-3 text-secondary opacity-25 ms-1 position-absolute" style="line-height: 0; bottom: -5px;">&rdquo;</span>
                    </p>
                </div>
                
                <div class="text-end mt-2">
                    <a href="#" class="d-inline-flex align-items-center gap-1 text-decoration-none" style="color: #0d9488; font-size: 0.85rem; font-weight: 600;">
                        <i data-lucide="refresh-cw" style="width: 14px; height: 14px;"></i> Refresh Tip
                    </a>
                </div>
            </div>
            
        </div>
    </div>
</div>

