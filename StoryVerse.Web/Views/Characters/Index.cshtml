@model IEnumerable<StoryVerse.Core.Entities.Character>
@{
    var story = ViewBag.Story as StoryVerse.Core.Entities.Story;
    ViewData["Title"] = $"Characters - {story?.Title}";
}

<div class="w-full pb-5 relative z-10 font-sans text-slate-800">
    <!-- Header Section -->
    <div class="d-flex align-items-center justify-content-between mb-4 mt-2">
        <div>
            <h2 class="font-serif fw-bold text-slate-900 mb-1" style="font-size: 28px; color: var(--forest-green-dark);">
                Characters <span class="text-warning fs-4">✦</span>
            </h2>
            <p class="text-secondary mb-0" style="font-size: 0.875rem;">Build memorable people for your story and outline their roles.</p>
        </div>

        <div class="d-flex gap-2">
            <a href="@Url.Action("Details", "Stories", new { id = story?.Id })" class="btn btn-outline-secondary rounded-pill px-4 py-2 d-flex align-items-center hover-lift-subtle" style="font-size: 0.85rem; font-weight: 700; border-color: var(--parchment-border) !important;">
                <i data-lucide="arrow-left" class="me-1.5" style="width: 16px; height: 16px;"></i> Story Overview
            </a>

            <a href="@Url.Action("Create", "Characters", new { storyId = story?.Id })" class="btn text-white rounded-pill px-4 py-2 d-flex align-items-center shadow-sm hover-lift-subtle" 
               style="background: var(--peacock-gradient); font-size: 0.85rem; font-weight: 700; border: none;">
                <i data-lucide="plus" class="me-1.5" style="width: 16px; height: 16px;"></i> New Character
            </a>
        </div>
    </div>

    <!-- Stats summary grid -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="dashboard-glass-panel p-4 d-flex align-items-center gap-3" style="background: var(--parchment-card); border: 1px solid var(--parchment-border);">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-peacock-teal" style="width: 48px; height: 48px; background: rgba(19, 168, 166, 0.1);">
                    <i data-lucide="users"></i>
                </div>
                <div>
                    <span class="text-secondary fw-semibold text-uppercase d-block" style="font-size: 10px; letter-spacing: 0.05em;">Total Characters</span>
                    <h4 class="fw-bold text-slate-800 mb-0 font-serif">@Model.Count()</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dashboard-glass-panel p-4 d-flex align-items-center gap-3" style="background: var(--parchment-card); border: 1px solid var(--parchment-border);">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-peacock-dark" style="width: 48px; height: 48px; background: rgba(30, 67, 155, 0.1);">
                    <i data-lucide="crown"></i>
                </div>
                <div>
                    <span class="text-secondary fw-semibold text-uppercase d-block" style="font-size: 10px; letter-spacing: 0.05em;">Key Roles Mapped</span>
                    <h4 class="fw-bold text-slate-800 mb-0 font-serif">@Model.Count(c => !string.IsNullOrEmpty(c.Role))</h4>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dashboard-glass-panel p-4 d-flex align-items-center gap-3" style="background: var(--parchment-card); border: 1px solid var(--parchment-border);">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-warning" style="width: 48px; height: 48px; background: rgba(255, 215, 0, 0.1);">
                    <i data-lucide="star"></i>
                </div>
                <div>
                    <span class="text-secondary fw-semibold text-uppercase d-block" style="font-size: 10px; letter-spacing: 0.05em;">Main Characters</span>
                    <h4 class="fw-bold text-slate-800 mb-0 font-serif">@Model.Count(c => c.Role.Contains("Protagonist", StringComparison.OrdinalIgnoreCase))</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Character Grid -->
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var character in Model)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card border-0 shadow-xs rounded-4 overflow-hidden transition-all hover-lift-subtle" style="background: var(--parchment-card); border: 1px solid var(--parchment-border) !important;">
                        <!-- Avatar placeholder with initial -->
                        <div class="p-4 text-center border-bottom bg-white/40 d-flex flex-column align-items-center justify-content-center" style="min-height: 140px;">
                            <div class="rounded-circle d-flex align-items-center justify-content-center font-serif text-white fw-bold mb-3 shadow" 
                                 style="width: 70px; height: 70px; background: var(--peacock-gradient); font-size: 1.85rem;">
                                @(string.IsNullOrEmpty(character.Name) ? "?" : character.Name[0].ToString().ToUpper())
                            </div>
                            <h5 class="fw-bold text-slate-800 mb-1 font-serif">@character.Name</h5>
                            <span class="badge bg-light text-secondary border px-3 py-1.5 rounded-pill text-uppercase" style="font-size: 10px; font-weight: 700; letter-spacing: 0.02em;">
                                @(string.IsNullOrEmpty(character.Role) ? "Character" : character.Role)
                            </span>
                        </div>

                        <!-- Card content info -->
                        <div class="p-3 bg-white/80 d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Created @character.CreatedAt.ToString("MM/dd/yyyy")</span>
                            <div class="d-flex gap-2">
                                <a href="@Url.Action("Details", "Characters", new { id = character.Id })" class="btn btn-sm btn-light border px-2.5 shadow-xs" title="View details">
                                    <i data-lucide="eye" style="width: 14px; height: 14px; color: var(--forest-green);"></i>
                                </a>
                                <a href="@Url.Action("Edit", "Characters", new { id = character.Id })" class="btn btn-sm btn-light border px-2.5 shadow-xs" title="Edit settings">
                                    <i data-lucide="edit-3" style="width: 14px; height: 14px; color: var(--forest-green-dark);"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-light border px-2.5 shadow-xs text-danger" title="Delete Character"
                                        data-bs-toggle="modal" data-bs-target="#deleteCharModal-@character.Id">
                                    <i data-lucide="trash-2" style="width: 14px; height: 14px;"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Delete Character Modal -->
                    <div class="modal fade" id="deleteCharModal-@character.Id" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                                <div class="p-4 text-center">
                                    <div class="rounded-circle bg-danger-subtle text-danger mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                        <i data-lucide="alert-triangle" style="width: 32px; height: 32px;"></i>
                                    </div>
                                    <h4 class="font-serif fw-bold text-slate-800 mb-2">Delete Character</h4>
                                    <p class="text-secondary small mb-4">Are you sure you want to delete @character.Name? This action is irreversible.</p>
                                    
                                    <div class="d-flex justify-content-center gap-3">
                                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                        <form asp-action="Delete" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@character.Id" />
                                            <button type="submit" class="btn btn-danger rounded-pill px-4">Delete Character</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 64px; height: 64px;">
                    <i data-lucide="users" class="text-secondary opacity-50" style="width: 32px; height: 32px;"></i>
                </div>
                <h5 class="fw-bold text-slate-700 mb-1">No Characters Created</h5>
                <p class="text-secondary small mb-4">Add characters to outline your story cast and define relationships.</p>
                <a href="@Url.Action("Create", "Characters", new { storyId = story?.Id })" class="btn text-white rounded-pill px-4 py-2" style="background: var(--peacock-gradient); border: none;">
                    Add First Character
                </a>
            </div>
        }
    </div>
</div>
