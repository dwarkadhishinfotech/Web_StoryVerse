@model IEnumerable<StoryVerse.Core.Entities.Chapter>
@{
    var story = ViewBag.Story as StoryVerse.Core.Entities.Story;
    ViewData["Title"] = $"Chapters - {story?.Title}";
}

<div class="w-full pb-5 relative z-10 font-sans text-slate-800">
    <!-- Header Section -->
    <div class="d-flex align-items-center justify-content-between mb-4 mt-2">
        <div>
            <h2 class="font-serif fw-bold text-slate-900 mb-1" style="font-size: 28px; color: var(--forest-green-dark);">
                Chapters - @story?.Title <span class="text-warning fs-4">✦</span>
            </h2>
            <p class="text-secondary mb-0" style="font-size: 0.875rem;">Manage, order, and write the chapters of your story.</p>
        </div>

        <div class="d-flex gap-2">
            <a href="@Url.Action("Details", "Stories", new { id = story?.Id })" class="btn btn-outline-secondary rounded-pill px-4 py-2 d-flex align-items-center hover-lift-subtle" style="font-size: 0.85rem; font-weight: 700; border-color: var(--parchment-border) !important;">
                <i data-lucide="arrow-left" class="me-1.5" style="width: 16px; height: 16px;"></i> Story Overview
            </a>

            <form asp-action="Create" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="storyId" value="@story?.Id" />
                <button type="submit" class="btn text-white rounded-pill px-4 py-2 d-flex align-items-center shadow-sm hover-lift-subtle" 
                        style="background: var(--peacock-gradient); font-size: 0.85rem; font-weight: 700; border: none;">
                    <i data-lucide="plus" class="me-1.5" style="width: 16px; height: 16px;"></i> New Chapter
                </button>
            </form>
        </div>
    </div>

    <!-- Chapters Table Container -->
    <div class="dashboard-glass-panel border overflow-hidden mb-4" style="background: var(--parchment-card); border-color: var(--parchment-border) !important;">
        <!-- Header row -->
        <div class="row g-3 px-4 py-3 border-bottom border-light align-items-center" style="font-size: 11px; font-weight: 700; color: #94A3B8; text-transform: uppercase; tracking: 0.1em;">
            <div class="col-5">Chapter</div>
            <div class="col-3">Word Progress</div>
            <div class="col-2">Last Updated</div>
            <div class="col-2 text-end">Actions</div>
        </div>

        <!-- Chapters List -->
        <div class="p-3 d-flex flex-column gap-2">
            @if (Model != null && Model.Any())
            {
                foreach (var chapter in Model)
                {
                    var storyTargetWords = story?.TargetWordCount ?? 50000;
                    var percent = storyTargetWords > 0 ? (int)Math.Clamp(((double)chapter.WordCount / storyTargetWords) * 100, 0, 100) : 0;

                    <div class="row g-3 px-3 py-3 align-items-center rounded-4 border bg-white shadow-xs transition-all hover-lift-subtle" style="border-color: #F1F5F9 !important;">
                        <!-- Chapter info -->
                        <div class="col-5 d-flex align-items-center gap-3">
                            <div class="rounded-3 d-flex align-items-center justify-content-center fw-bold font-serif text-white flex-shrink-0" 
                                 style="width: 42px; height: 42px; background: var(--peacock-gradient); font-size: 1.15rem; box-shadow: 0 4px 10px rgba(19, 168, 166, 0.15);">
                                @chapter.Order
                            </div>
                            <div class="min-w-0">
                                <a href="@Url.Action("Editor", "Chapters", new { storyId = story?.Id, chapterId = chapter.Id })" class="text-decoration-none">
                                    <h6 class="fw-bold mb-1 text-slate-800 text-truncate text-uppercase hover-text-teal" style="font-size: 0.9rem; transition: color 0.2s;">
                                        @chapter.Title
                                    </h6>
                                </a>
                                <div class="d-flex align-items-center text-muted gap-2" style="font-size: 11px;">
                                    <span class="d-flex align-items-center">
                                        <i data-lucide="calendar" class="me-1" style="width: 12px; height: 12px;"></i>
                                        @chapter.CreatedAt.ToString("MM/dd/yyyy")
                                    </span>
                                    <span class="bg-light text-secondary px-2 py-0.5 rounded font-monospace" style="font-size: 9px; font-weight: 700; letter-spacing: 0.05em;">
                                        DRAFT
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Word Progress -->
                        <div class="col-3">
                            <div class="d-flex justify-content-between align-items-baseline mb-1">
                                <span class="fw-bold text-slate-700" style="font-size: 13px;">@chapter.WordCount.ToString("N0") <span class="text-muted fw-semibold" style="font-size: 11px;">words</span></span>
                                <span class="text-secondary font-monospace" style="font-size: 11px;">@percent%</span>
                            </div>
                            <div class="progress" style="height: 6px; background-color: #F1F5F9; border-radius: 10px; overflow: hidden;">
                                <div class="progress-bar" role="progressbar" style="width: @percent%; background: var(--peacock-gradient); border-radius: 10px;" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>

                        <!-- Last Updated -->
                        <div class="col-2 text-secondary" style="font-size: 12px; font-weight: 500;">
                            @chapter.UpdatedAt.ToString("g")
                        </div>

                        <!-- Actions -->
                        <div class="col-2 d-flex justify-content-end gap-2">
                            <a href="@Url.Action("Editor", "Chapters", new { storyId = story.Id, chapterId = chapter.Id })" 
                               class="btn btn-white border rounded-3 p-2 d-flex align-items-center justify-content-center text-secondary hover-lift-subtle shadow-xs" 
                               style="width: 36px; height: 36px; border-color: var(--parchment-border) !important;" title="Edit Chapter">
                                <i data-lucide="pen-tool" class="text-peacock-teal" style="width: 16px; height: 16px;"></i>
                            </a>

                            <button type="button" class="btn btn-white border rounded-3 p-2 d-flex align-items-center justify-content-center text-danger hover-lift-subtle shadow-xs" 
                                    style="width: 36px; height: 36px; border-color: var(--parchment-border) !important;" title="Delete Chapter"
                                    data-bs-toggle="modal" data-bs-target="#deleteModal-@chapter.Id">
                                <i data-lucide="trash-2" style="width: 16px; height: 16px;"></i>
                            </button>

                            <!-- Delete Modal -->
                            <div class="modal fade" id="deleteModal-@chapter.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                                        <div class="p-4 text-center">
                                            <div class="rounded-circle bg-danger-subtle text-danger mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                                <i data-lucide="alert-triangle" style="width: 32px; height: 32px;"></i>
                                            </div>
                                            <h4 class="font-serif fw-bold text-slate-800 mb-2">Delete Chapter</h4>
                                            <p class="text-secondary small mb-4">Are you sure you want to delete "@chapter.Title"? This action cannot be undone.</p>
                                            
                                            <div class="d-flex justify-content-center gap-3">
                                                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                                                <form asp-action="Delete" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@chapter.Id" />
                                                    <button type="submit" class="btn btn-danger rounded-pill px-4">Delete Chapter</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 64px; height: 64px;">
                        <i data-lucide="scroll" class="text-secondary opacity-50" style="width: 32px; height: 32px;"></i>
                    </div>
                    <h5 class="fw-bold text-slate-700 mb-1">No Chapters Created</h5>
                    <p class="text-secondary small mb-4">Start organizing your story structure by adding your first chapter.</p>
                    <form asp-action="Create" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="storyId" value="@story?.Id" />
                        <button type="submit" class="btn text-white rounded-pill px-4 py-2" style="background: var(--peacock-gradient); border: none;">
                            Add First Chapter
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .hover-text-teal:hover {
        color: var(--forest-green) !important;
    }
</style>
