@model StoryVerse.Core.Entities.Chapter
@{
    Layout = null;
    var story = ViewBag.Story as StoryVerse.Core.Entities.Story;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title - Editor - StoryVerse</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    
    <style>
        :root {
            --parchment-bg: #FAF5ED;
            --forest-green: #13A8A6;
            --forest-green-dark: #1E439B;
            --parchment-border: #EAE3D2;
            --parchment-card: rgba(253, 251, 247, 0.95);
            --peacock-gradient: linear-gradient(135deg, #1E439B, #13A8A6);
        }
        body { 
            background-color: var(--parchment-bg);
            background-image: url('/backgrounds/SiteBgPage.png') !important;
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            font-family: 'Inter', sans-serif;
            color: #1C2B39;
            height: 100vh;
            overflow: hidden;
            margin: 0;
        }
        .editor-layout {
            display: grid;
            grid-template-rows: 70px 1fr;
            height: 100vh;
            width: 100vw;
        }
        .sv-editor-toolbar {
            background: rgba(253, 251, 247, 0.9);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--parchment-border);
            z-index: 1000;
        }
        .workspace-split {
            display: grid;
            grid-template-columns: 1fr 320px;
            overflow: hidden;
            height: 100%;
        }
        .writing-pane {
            overflow-y: auto;
            padding: 4rem 2rem;
            display: flex;
            justify-content: center;
        }
        .canvas-container {
            max-width: 800px;
            width: 100%;
        }
        .sv-editor-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.75rem;
            font-weight: 700;
            border: none;
            background: transparent;
            width: 100%;
            outline: none;
            margin-bottom: 1.5rem;
            color: var(--forest-green-dark);
            border-bottom: 1px dashed transparent;
            transition: all 0.2s;
        }
        .sv-editor-title:focus {
            border-bottom-color: var(--forest-green);
        }
        .sv-editor-title::placeholder {
            color: #CED4DA;
        }
        .sv-editor-content {
            font-family: 'Merriweather', serif;
            font-size: 1.15rem;
            line-height: 1.95;
            color: #2D3748;
            outline: none;
            min-height: 70vh;
            padding-bottom: 10rem;
        }
        .sv-editor-content p {
            margin-bottom: 1.6rem;
        }
        .sv-editor-content[placeholder]:empty:before {
            content: attr(placeholder);
            color: #A0AEC0;
            pointer-events: none;
            display: block;
        }
        .sidebar-pane {
            background: rgba(253, 251, 247, 0.95);
            border-left: 1px solid var(--parchment-border);
            backdrop-filter: blur(12px);
            display: flex;
            flex-column: column;
            overflow-y: auto;
            padding: 1.5rem;
        }
        .text-peacock {
            color: var(--forest-green);
        }
        .btn-peacock {
            background: var(--peacock-gradient);
            color: white;
            border: none;
            transition: opacity 0.2s;
        }
        .btn-peacock:hover {
            opacity: 0.95;
            color: white;
        }
        .save-indicator {
            font-size: 11px;
            font-weight: 600;
            color: var(--forest-green);
            display: flex;
            align-items: center;
            gap: 4px;
        }
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(19, 168, 166, 0.2);
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <div class="editor-layout">
        <!-- Top Toolbar -->
        <header class="sv-editor-toolbar px-4 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a href="@Url.Action("Index", "Chapters", new { storyId = Model.StoryId })" class="btn btn-link p-2 text-secondary hover-lift-subtle rounded-circle bg-light border me-3" title="Back to Chapters">
                    <i data-lucide="arrow-left" style="width:18px;height:18px;"></i>
                </a>
                <div>
                    <h6 class="mb-0 fw-bold text-slate-800 uppercase" style="font-size: 0.85rem; letter-spacing: 0.05em;">@story?.Title</h6>
                    <div class="save-indicator">
                        <i data-lucide="cloud-check" style="width: 12px; height: 12px;"></i>
                        <span id="saveStatus">Saved</span>
                    </div>
                </div>
            </div>
            
            <div class="d-flex align-items-center gap-3">
                <div class="text-secondary small fw-bold font-monospace bg-white border rounded-3 px-3 py-1.5 shadow-xs">
                    <span id="wordCount">0</span> words • <span id="charCount">0</span> chars
                </div>
                
                <div class="vr bg-secondary opacity-25"></div>
                
                <button class="btn btn-light rounded-3 p-2 shadow-xs border" onclick="execCmd('bold')" title="Bold">
                    <i data-lucide="bold" style="width:16px;height:16px;"></i>
                </button>
                <button class="btn btn-light rounded-3 p-2 shadow-xs border" onclick="execCmd('italic')" title="Italic">
                    <i data-lucide="italic" style="width:16px;height:16px;"></i>
                </button>
                <button class="btn btn-light rounded-3 p-2 shadow-xs border" onclick="execCmd('underline')" title="Underline">
                    <i data-lucide="underline" style="width:16px;height:16px;"></i>
                </button>
                
                <div class="vr bg-secondary opacity-25"></div>
                
                <button class="btn btn-peacock rounded-pill px-4 fw-bold shadow-xs hover-lift-subtle" onclick="saveContent()">
                    <i data-lucide="save" class="me-1" style="width: 16px; height: 16px; vertical-align: middle;"></i> Save
                </button>
            </div>
        </header>

        <!-- Main Workspace -->
        <div class="workspace-split">
            <!-- Writing Pane -->
            <div class="writing-pane custom-scrollbar">
                <div class="canvas-container">
                    <input type="text" id="chapterTitle" class="sv-editor-title" placeholder="Chapter Title" value="@Model.Title" />
                    
                    <div id="editorCanvas" class="sv-editor-content" contenteditable="true" placeholder="Once upon a time...">
                        <p>Write your chapter contents here...</p>
                    </div>
                </div>
            </div>

            <!-- Sidebar Info Panel -->
            <div class="sidebar-pane d-flex flex-column gap-4 border-start">
                <div>
                    <h5 class="font-serif fw-bold text-peacock mb-3 flex items-center gap-2">
                        <i data-lucide="compass" class="d-inline-block text-peacock align-middle" style="width:18px;height:18px;"></i>
                        Chapter Info
                    </h5>
                    <div class="d-flex flex-column gap-2 bg-white p-3 rounded-4 border shadow-xs" style="font-size: 13px;">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Order</span>
                            <span class="fw-bold">Chapter @Model.Order</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Created</span>
                            <span class="fw-bold">@Model.CreatedAt.ToString("MM/dd/yyyy")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Status</span>
                            <span class="badge bg-teal-subtle text-teal-700 font-bold uppercase tracking-wider" style="font-size: 9px;">Draft</span>
                        </div>
                    </div>
                </div>

                <hr class="text-muted opacity-25 m-0" />

                <div class="flex-grow-1">
                    <h5 class="font-serif fw-bold text-peacock mb-3">
                        <i data-lucide="scroll" class="d-inline-block text-peacock align-middle me-1" style="width:18px;height:18px;"></i>
                        Workspace Notes
                    </h5>
                    <textarea class="form-control rounded-4 border-slate-200" rows="8" placeholder="Jot down quick reminders or character references while writing..." style="font-size: 13px; background: rgba(255,255,255,0.7); resize: none;"></textarea>
                </div>
                
                <div class="p-3 bg-light rounded-4 border">
                    <h6 class="fw-bold mb-2 small text-uppercase tracking-wider text-secondary">Tip for Authors</h6>
                    <p class="text-muted mb-0" style="font-size: 11px; line-height: 1.5;">Try setting a daily goal to maintain your writing momentum. Every small paragraph brings you closer to completing your manuscript.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Initialize Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        lucide.createIcons();

        const titleInput = document.getElementById('chapterTitle');
        const editor = document.getElementById('editorCanvas');
        const wordCountDisplay = document.getElementById('wordCount');
        const charCountDisplay = document.getElementById('charCount');
        const saveStatusText = document.getElementById('saveStatus');

        function updateCounts() {
            const text = editor.innerText || editor.textContent;
            const words = text.trim().split(/\s+/).filter(word => word.length > 0);
            wordCountDisplay.textContent = words.length.toLocaleString();
            charCountDisplay.textContent = text.length.toLocaleString();
        }

        editor.addEventListener('input', () => {
            updateCounts();
            setUnsaved();
        });

        titleInput.addEventListener('input', () => {
            setUnsaved();
        });

        function setUnsaved() {
            saveStatusText.textContent = "Unsaved Changes";
            saveStatusText.style.color = "#FF9F43";
        }

        function saveContent() {
            saveStatusText.textContent = "Saving...";
            saveStatusText.style.color = "var(--forest-green)";
            
            // Simulating save
            setTimeout(() => {
                saveStatusText.textContent = "Saved";
                saveStatusText.style.color = "var(--forest-green)";
            }, 800);
        }

        function execCmd(command) {
            document.execCommand(command, false, null);
            editor.focus();
        }

        // Initialize counts
        updateCounts();

        // Auto-save simulation
        setInterval(() => {
            if (saveStatusText.textContent === "Unsaved Changes") {
                saveContent();
            }
        }, 5000);
    </script>
</body>
</html>
